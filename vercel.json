{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/:path((?!api/).*)", "destination": "/index.html" }
  ]
}

